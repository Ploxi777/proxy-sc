# Optional. If omitted, the project will fall back to the legacy client_id mode.
# Recommended for production stability.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# Optional. If you already have a valid access token, set it here.
# When present, it is used instead of the client credentials flow.
SOUNDCLOUD_ACCESS_TOKEN=

# Optional overrides for the target resources.
SOUNDCLOUD_USER_URL=https://soundcloud.com/arekkuzzera
SOUNDCLOUD_TRACK_URL=https://soundcloud.com/arekkuzzera/psycho-dreams-hardstyle-remix

# Optional CORS allow list. Use * for public access or comma-separated origins.
CORS_ALLOW_ORIGIN=*

# Optional operational tuning.
SOUNDCLOUD_API_BASE_URL=https://api-v2.soundcloud.com
SOUNDCLOUD_TOKEN_URL=https://secure.soundcloud.com/oauth/token
SOUNDCLOUD_REQUEST_TIMEOUT_MS=10000
SOUNDCLOUD_MAX_COLLECTION_PAGES=20
SOUNDCLOUD_PAGE_LIMIT=200

# Set to false if you want only live totals without manual corrections/history.
DASHBOARD_INCLUDE_MANUAL_ADJUSTMENTS=true
